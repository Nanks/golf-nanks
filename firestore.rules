rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. PLAYERS & ROUNDS
    match /players/{playerKey} {
      // Allow the single-document phone number query for login
      allow list: if request.auth == null && request.query.limit <= 1;

      // Allow all authenticated users to read profiles and view the roster
      allow read: if true;
      allow list: if request.auth != null;

      // Admin-only write access for specific UIDs
      allow write: if request.auth != null && (
        request.auth.uid == "uAXVYJHK1hRJUwHzY0G6jWmT7hE2" || 
        request.auth.uid == "oqbNxGVTosT0SiuTmqjzVCvGlcf2"
      );
      
      allow update: if request.auth != null && (
        // Scenario A: The document doesn't have a 'uids' field yet
        !("uids" in resource.data) || 
        // Scenario B: The user is already in the 'uids' list (safe re-link)
        request.auth.uid in resource.data.uids ||
        // Scenario C: You are one of the designated Admins
        request.auth.uid == "uAXVYJHK1hRJUwHzY0G6jWmT7hE2" || 
        request.auth.uid == "oqbNxGVTosT0SiuTmqjzVCvGlcf2"
      );
			
      allow delete: if request.auth != null && (
        request.auth.uid == "uAXVYJHK1hRJUwHzY0G6jWmT7hE2" || 
        request.auth.uid == "oqbNxGVTosT0SiuTmqjzVCvGlcf2"
      );
      
      // Deeply nested rounds access (required for roster audits)
      match /rounds/{roundId} {
        allow read: if true; 
        allow write: if request.auth != null;
      }
    }

    // 2. LEAGUES & CALENDARS
    match /leagues/{leagueId} {
      // Public read for league details, authenticated for everything else
      allow read: if true;
      allow write: if request.auth != null;
      
      match /weeklyStats/{statsId} {
        // Allows any authenticated user to write. 
        // You can restrict this to only Admins later if preferred.
        allow read, write: if request.auth != null;
      }
  
      match /calendar/{entryId} {
        allow read: if true
        allow write: if request.auth != null;
      }
    }

    // 3. COURSES & TEES (Crucial for Handicap Calc)
    // Using recursive wildcards {path=**} ensures all sub-tees are readable
    match /courses/{courseId} {
      allow read: if true
      allow write: if request.auth != null;
      
      match /tees/{teeId} {
        allow read: if true 
        allow write: if request.auth != null;
      }
    }

    // 4. GLOBAL ROUNDS SEARCH (Fallback)
    // Allows queries like your "last 10 rounds" that search across the DB
    match /{path=**}/rounds/{roundId} {
      allow read: if request.auth != null;
    }
    
    match /live_rounds/{roundId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /{path=**}/tees/{teeId} {
      allow read: if request.auth != null;
    }
  }
}
